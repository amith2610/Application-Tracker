# Database - SQLite file path (relative to prisma/)
DATABASE_URL="file:./dev.db"

# Session (required for login) - use a random string of at least 32 characters
SESSION_PASSWORD=your_32_char_or_longer_secret_session_key

# Gmail import (AI + OAuth)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# New user notification (optional) - email sent when someone signs up so you can add them to Google Cloud test users
# ADMIN_EMAIL=admin@example.com
# RESEND_API_KEY=re_xxxx
# FROM_EMAIL=onboarding@resend.dev

# Hugging Face (Gmail classification + AI Resume Match)
HUGGINGFACE_API_KEY=your_hf_token
# Optional: model for resume match (default: google/gemma-2-2b-it). Use a model you have enabled at huggingface.co/inference
# HF_RESUME_MODEL=google/gemma-2-2b-it
# Optional: fallback model if primary returns 503 (default: microsoft/DialoGPT-large)
# HF_RESUME_FALLBACK_MODEL=microsoft/DialoGPT-large
# Optional: legacy text-generation model when provider models are not enabled (default: google/flan-t5-large)
# HF_RESUME_LEGACY_MODEL=google/flan-t5-large

# Optional: Base URL for share links (when deployed)
# NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Optional: Data directory for production (SQLite + uploads). Set to /data when using Fly.io volume.
# DATA_DIR=/data
